{
  "name": "comment-doc-lens",
  "displayName": "Comment Doc Lens",
  "description": "Show definition comments and symbol documentation inline at reference sites.",
  "version": "0.2.1",
  "icon": "assets/icon.png",
  "publisher": "tanzz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tzzs/comment-doc-lens.git"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "comments",
    "documentation",
    "inlay hints",
    "go",
    "typescript",
    "javascript",
    "jsdoc",
    "vscode extension"
  ],
  "files": [
    "assets/icon.png",
    "out/src/**/*.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "activationEvents": [
    "onLanguage:go",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onCommand:commentDocLens.toggle",
    "onCommand:commentDocLens.refresh"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commentDocLens.toggle",
        "title": "Comment Doc Lens: Toggle"
      },
      {
        "command": "commentDocLens.refresh",
        "title": "Comment Doc Lens: Refresh"
      }
    ],
    "configuration": {
      "title": "Comment Doc Lens",
      "properties": {
        "commentDocLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Comment Doc Lens inlay hints."
        },
        "commentDocLens.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "go",
            "typescript",
            "javascript",
            "typescriptreact",
            "javascriptreact"
          ],
          "description": "Language identifiers where Comment Doc Lens runs."
        },
        "commentDocLens.maxHintLength": {
          "type": "number",
          "default": 120,
          "minimum": 20,
          "description": "Maximum length of the inline comment summary."
        },
        "commentDocLens.maxHintsPerRequest": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "description": "Maximum number of hints produced per inlay hint request."
        },
        "commentDocLens.minIdentifierLength": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Minimum identifier length before hints are shown unless documentation includes a definition location."
        },
        "commentDocLens.preferPropertyTail": {
          "type": "boolean",
          "default": true,
          "description": "Prefer the final identifier in property chains, such as baz in foo.bar.baz."
        },
        "commentDocLens.dedupeLineHints": {
          "type": "boolean",
          "default": true,
          "description": "Deduplicate repeated inlay hint summaries on the same line."
        },
        "commentDocLens.resolveTimeoutMs": {
          "type": "number",
          "default": 750,
          "minimum": 100,
          "description": "Maximum time in milliseconds to wait for a single documentation lookup."
        },
        "commentDocLens.maxCacheEntries": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "description": "Maximum number of cached documentation lookup results."
        },
        "commentDocLens.hintPrefix": {
          "type": "string",
          "default": "// ",
          "description": "Prefix displayed before each inline documentation summary."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node --test out/test/*.test.js",
    "test:integration": "npm run compile && node out/test/integration/runTest.js",
    "test:all": "npm test && npm run test:integration",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.101.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.5.2"
  }
}
