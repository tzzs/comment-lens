{
  "name": "comment-doc-lens",
  "displayName": "Comment Doc Lens",
  "description": "Show definition comments and symbol documentation inline at reference sites.",
  "version": "0.6.1",
  "icon": "assets/icon.png",
  "publisher": "tanzz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tzzs/comment-doc-lens.git"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "comments",
    "csharp",
    "cpp",
    "documentation",
    "inlay hints",
    "go",
    "java",
    "kotlin",
    "php",
    "python",
    "ruby",
    "rust",
    "swift",
    "typescript",
    "javascript",
    "jsdoc",
    "vscode extension"
  ],
  "files": [
    "assets/icon.png",
    "assets/social-preview.png",
    "assets/social-preview.svg",
    "assets/demo-before.png",
    "assets/demo-after.png",
    "out/src/**/*.js",
    "package.nls.json",
    "package.nls.zh-cn.json",
    "docs/**/*.md",
    "README.md",
    "README_CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "activationEvents": [
    "onLanguage:go",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:rust",
    "onLanguage:csharp",
    "onLanguage:php",
    "onLanguage:ruby",
    "onLanguage:kotlin",
    "onLanguage:swift",
    "onLanguage:c",
    "onLanguage:cpp",
    "onCommand:commentDocLens.toggle",
    "onCommand:commentDocLens.refresh",
    "onCommand:commentDocLens.showLanguageStatus",
    "onCommand:commentDocLens.diagnoseWorkspace",
    "onCommand:commentDocLens.copyDiagnosticsForIssue",
    "onCommand:commentDocLens.explainHiddenHint",
    "onCommand:commentDocLens.openSampleGallery"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commentDocLens.toggle",
        "title": "%commentDocLens.commands.toggle.title%"
      },
      {
        "command": "commentDocLens.refresh",
        "title": "%commentDocLens.commands.refresh.title%"
      },
      {
        "command": "commentDocLens.showLanguageStatus",
        "title": "%commentDocLens.commands.showLanguageStatus.title%"
      },
      {
        "command": "commentDocLens.diagnoseWorkspace",
        "title": "%commentDocLens.commands.diagnoseWorkspace.title%"
      },
      {
        "command": "commentDocLens.copyDiagnosticsForIssue",
        "title": "%commentDocLens.commands.copyDiagnosticsForIssue.title%"
      },
      {
        "command": "commentDocLens.explainHiddenHint",
        "title": "%commentDocLens.commands.explainHiddenHint.title%"
      },
      {
        "command": "commentDocLens.openSampleGallery",
        "title": "%commentDocLens.commands.openSampleGallery.title%"
      }
    ],
    "configuration": {
      "title": "Comment Doc Lens",
      "properties": {
        "commentDocLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%commentDocLens.configuration.enabled.description%"
        },
        "commentDocLens.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "go",
            "typescript",
            "javascript",
            "typescriptreact",
            "javascriptreact",
            "python",
            "java",
            "rust",
            "csharp",
            "php",
            "ruby",
            "kotlin",
            "swift",
            "c",
            "cpp"
          ],
          "description": "%commentDocLens.configuration.languages.description%"
        },
        "commentDocLens.languageOverrides": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "%commentDocLens.configuration.languageOverrides.enabled.description%"
              }
            }
          },
          "description": "%commentDocLens.configuration.languageOverrides.description%"
        },
        "commentDocLens.maxLineLength": {
          "type": "number",
          "default": 2000,
          "minimum": 80,
          "description": "%commentDocLens.configuration.maxLineLength.description%"
        },
        "commentDocLens.maxHintLength": {
          "type": "number",
          "default": 120,
          "minimum": 20,
          "description": "%commentDocLens.configuration.maxHintLength.description%"
        },
        "commentDocLens.maxHintsPerRequest": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "description": "%commentDocLens.configuration.maxHintsPerRequest.description%"
        },
        "commentDocLens.maxHintsPerLine": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "%commentDocLens.configuration.maxHintsPerLine.description%"
        },
        "commentDocLens.minIdentifierLength": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "%commentDocLens.configuration.minIdentifierLength.description%"
        },
        "commentDocLens.minimumDocumentationWords": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "description": "%commentDocLens.configuration.minimumDocumentationWords.description%"
        },
        "commentDocLens.preferPropertyTail": {
          "type": "boolean",
          "default": true,
          "description": "%commentDocLens.configuration.preferPropertyTail.description%"
        },
        "commentDocLens.dedupeLineHints": {
          "type": "boolean",
          "default": true,
          "description": "%commentDocLens.configuration.dedupeLineHints.description%"
        },
        "commentDocLens.resolveTimeoutMs": {
          "type": "number",
          "default": 750,
          "minimum": 100,
          "description": "%commentDocLens.configuration.resolveTimeoutMs.description%"
        },
        "commentDocLens.maxCacheEntries": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "description": "%commentDocLens.configuration.maxCacheEntries.description%"
        },
        "commentDocLens.hintPrefix": {
          "type": "string",
          "default": "// ",
          "description": "%commentDocLens.configuration.hintPrefix.description%"
        },
        "commentDocLens.enableHintInteractions": {
          "type": "boolean",
          "default": false,
          "description": "%commentDocLens.configuration.enableHintInteractions.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node --test out/test/*.test.js",
    "test:coverage": "npm run compile && node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 out/test/*.test.js",
    "test:integration": "npm run compile && node out/test/integration/runTest.js",
    "test:all": "npm test && npm run test:integration",
    "harness:check": "node scripts/check-harness-docs.js",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.101.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.5.2"
  }
}
