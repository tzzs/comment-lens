{
  "name": "comment-lens",
  "displayName": "Comment Lens",
  "description": "Show definition comments and symbol documentation inline at reference sites.",
  "version": "0.4.0",
  "icon": "assets/icon.png",
  "publisher": "tanzz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tzzs/comment-lens.git"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "comments",
    "csharp",
    "cpp",
    "documentation",
    "inlay hints",
    "go",
    "java",
    "kotlin",
    "php",
    "python",
    "ruby",
    "rust",
    "swift",
    "typescript",
    "javascript",
    "jsdoc",
    "vscode extension"
  ],
  "files": [
    "assets/icon.png",
    "out/src/**/*.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "activationEvents": [
    "onLanguage:go",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:rust",
    "onLanguage:csharp",
    "onLanguage:php",
    "onLanguage:ruby",
    "onLanguage:kotlin",
    "onLanguage:swift",
    "onLanguage:c",
    "onLanguage:cpp",
    "onCommand:commentLens.toggle",
    "onCommand:commentLens.refresh",
    "onCommand:commentLens.showLanguageStatus"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commentLens.toggle",
        "title": "Comment Lens: Toggle"
      },
      {
        "command": "commentLens.refresh",
        "title": "Comment Lens: Refresh"
      },
      {
        "command": "commentLens.showLanguageStatus",
        "title": "Comment Lens: Show Language Status"
      }
    ],
    "configuration": {
      "title": "Comment Lens",
      "properties": {
        "commentLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Comment Lens inlay hints."
        },
        "commentLens.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "go",
            "typescript",
            "javascript",
            "typescriptreact",
            "javascriptreact",
            "python",
            "java",
            "rust",
            "csharp",
            "php",
            "ruby",
            "kotlin",
            "swift",
            "c",
            "cpp"
          ],
          "description": "Registered adapter language identifiers where Comment Lens runs. This setting filters supported adapter languages; unknown language identifiers are ignored."
        },
        "commentLens.languageOverrides": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Enable or disable Comment Lens for this language."
              }
            }
          },
          "description": "Per-language Comment Lens settings keyed by VS Code language identifier. For example: { \"python\": { \"enabled\": false } }."
        },
        "commentLens.maxLineLength": {
          "type": "number",
          "default": 2000,
          "minimum": 80,
          "description": "Maximum source line length scanned for candidate symbols. Longer lines are skipped to avoid expensive lookups in generated or minified files."
        },
        "commentLens.maxHintLength": {
          "type": "number",
          "default": 120,
          "minimum": 20,
          "description": "Maximum length of the inline comment summary."
        },
        "commentLens.maxHintsPerRequest": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "description": "Maximum number of hints produced per inlay hint request."
        },
        "commentLens.minIdentifierLength": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Minimum identifier length before hints are shown unless documentation includes a definition location."
        },
        "commentLens.minimumDocumentationWords": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "description": "Minimum number of words required in a documentation summary before it can be shown."
        },
        "commentLens.preferPropertyTail": {
          "type": "boolean",
          "default": true,
          "description": "Prefer the final identifier in property chains, such as baz in foo.bar.baz."
        },
        "commentLens.dedupeLineHints": {
          "type": "boolean",
          "default": true,
          "description": "Deduplicate repeated inlay hint summaries on the same line."
        },
        "commentLens.resolveTimeoutMs": {
          "type": "number",
          "default": 750,
          "minimum": 100,
          "description": "Maximum time in milliseconds to wait for a single documentation lookup."
        },
        "commentLens.maxCacheEntries": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "description": "Maximum number of cached documentation lookup results."
        },
        "commentLens.hintPrefix": {
          "type": "string",
          "default": "// ",
          "description": "Prefix displayed before each inline documentation summary."
        },
        "commentLens.enableHintInteractions": {
          "type": "boolean",
          "default": false,
          "description": "Enable inlay hint label tooltips and definition locations when documentation lookup provides them."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node --test out/test/*.test.js",
    "test:integration": "npm run compile && node out/test/integration/runTest.js",
    "test:all": "npm test && npm run test:integration",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.101.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.5.2"
  }
}
